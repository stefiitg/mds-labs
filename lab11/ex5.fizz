action Init:
  color = "red"

atomic action ToGreen:
  require color == "red"
  color = "green"

atomic action ToYellow:
  require color == "green"
  color = "yellow"

atomic action ToRed:
  require color == "yellow"
  color = "red"

atomic action Break:
  require color != "broken"
  color = "broken"

atomic action Fix:
  require color == "broken"
  color = "red"
